package core

import (
	"github.com/QuarkChain/goquarkchain/account"
	"github.com/ethereum/go-ethereum/common"
)

func parsePOSAValidators(raw []string) []account.Address {
	validators := make([]account.Address, 0, len(raw))
	for _, addrHex := range raw {
		addrBytes := common.FromHex(addrHex)
		addr, err := account.CreatAddressFromBytes(addrBytes)
		if err != nil {
			continue
		}
		validators = append(validators, addr)
	}
	return validators
}

func proposerIndexForHeight(height uint64, validatorCount int) int {
	if validatorCount <= 0 {
		return -1
	}
	slot := height
	if slot > 0 {
		slot--
	}
	return int(slot % uint64(validatorCount))
}

