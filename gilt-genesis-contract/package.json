  "scripts": {
    "lint:check": "forge fmt ./contracts/GiltTimelock.sol ./contracts/GovToken.sol ./contracts/GiltGovernor.sol ./contracts/StakeCredit.sol ./contracts/StakeHub.sol ./contracts/stakehub ./contracts/SystemV2.sol --check",
    "lint:write": "forge fmt ./contracts/GiltTimelock.sol ./contracts/GovToken.sol ./contracts/GiltGovernor.sol ./contracts/StakeCredit.sol ./contracts/StakeHub.sol ./contracts/stakehub ./contracts/SystemV2.sol",
    "abi:export": "node scripts/abi-integrity.js export",
    "abi:check": "node scripts/abi-integrity.js check",
    "launch:validate": "node scripts/validate-launch-config.js",
    "launch:validate:testnet": "node scripts/validate-launch-config.js --profile testnet",
    "launch:validate:mainnet": "node scripts/validate-launch-config.js --profile mainnet",
    "launch:storage": "node scripts/check-launch-storage-layout.js",
    "launch:runtime": "node scripts/check-launch-runtime-size.js",
    "launch:genesis": "node scripts/generate-launch-genesis.js",
    "launch:genesis:testnet": "node scripts/generate-launch-genesis.js --profile testnet",
    "launch:genesis:mainnet": "node scripts/generate-launch-genesis.js --profile mainnet",
    "launch:report": "node scripts/print-launch-report.js",
    "launch:report:testnet": "node scripts/print-launch-report.js --profile testnet",
    "launch:report:mainnet": "node scripts/print-launch-report.js --profile mainnet",
    "launch:core": "node scripts/run-core-launch.js",
    "launch:core:testnet": "node scripts/run-core-launch.js --profile testnet",
    "launch:core:mainnet": "node scripts/run-core-launch.js --profile mainnet",
    "test:launch-config": "node scripts/test-launch-config.js"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.3",
