{<<"links">>,
 [{<<"Changelog">>,<<"https://github.com/Nebo15/logger_json/releases">>},
  {<<"GitHub">>,<<"https://github.com/Nebo15/logger_json">>}]}.
{<<"name">>,<<"logger_json">>}.
{<<"version">>,<<"7.0.4">>}.
{<<"description">>,
 <<"This package includes a set of :logger formatters designed to output logs in JSON format.\nIt is compatible with a variety of log management systems that support JSON,\nincluding Google Cloud Logging and Error Reporting, Datadog, ElasticSearch, LogStash, FileBeat, and Kibana.">>}.
{<<"elixir">>,<<"~> 1.16 or ~> 1.15.1">>}.
{<<"app">>,<<"logger_json">>}.
{<<"licenses">>,[<<"MIT">>]}.
{<<"files">>,
 [<<"lib">>,<<"lib/logger_json.ex">>,<<"lib/logger_json">>,
  <<"lib/logger_json/redactor.ex">>,<<"lib/logger_json/formatter.ex">>,
  <<"lib/logger_json/formatters">>,
  <<"lib/logger_json/formatters/google_cloud.ex">>,
  <<"lib/logger_json/formatters/datadog.ex">>,
  <<"lib/logger_json/formatters/basic.ex">>,
  <<"lib/logger_json/formatters/elastic.ex">>,<<"lib/logger_json/ecto.ex">>,
  <<"lib/logger_json/formatter">>,
  <<"lib/logger_json/formatter/map_builder.ex">>,
  <<"lib/logger_json/formatter/message.ex">>,
  <<"lib/logger_json/formatter/code.ex">>,
  <<"lib/logger_json/formatter/metadata.ex">>,
  <<"lib/logger_json/formatter/datetime.ex">>,
  <<"lib/logger_json/formatter/plug.ex">>,
  <<"lib/logger_json/formatter/redactor_encoder.ex">>,
  <<"lib/logger_json/redactors">>,
  <<"lib/logger_json/redactors/redact_keys.ex">>,
  <<"lib/logger_json/plug.ex">>,<<"LICENSE.md">>,<<"mix.exs">>,
  <<"README.md">>]}.
{<<"requirements">>,
 [[{<<"name">>,<<"jason">>},
   {<<"app">>,<<"jason">>},
   {<<"optional">>,true},
   {<<"requirement">>,<<"~> 1.4">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"plug">>},
   {<<"app">>,<<"plug">>},
   {<<"optional">>,true},
   {<<"requirement">>,<<"~> 1.15">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"decimal">>},
   {<<"app">>,<<"decimal">>},
   {<<"optional">>,true},
   {<<"requirement">>,<<">= 0.0.0">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"ecto">>},
   {<<"app">>,<<"ecto">>},
   {<<"optional">>,true},
   {<<"requirement">>,<<"~> 3.11">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"telemetry">>},
   {<<"app">>,<<"telemetry">>},
   {<<"optional">>,true},
   {<<"requirement">>,<<"~> 1.0">>},
   {<<"repository">>,<<"hexpm">>}]]}.
{<<"build_tools">>,[<<"mix">>]}.
